PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/team-task-manager
# Local only: in-memory Mongo (ignored when NODE_ENV=production)
USE_EMBEDDED_MONGO=true
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Comma-separated allowed frontend origins (required in production)
CLIENT_URL=http://localhost:3000

# Optional: grant admin role on signup when code matches (first user is always admin)
ADMIN_INVITE_CODE=your_secret_admin_invite_code

# Auth rate limit per IP per 15 minutes (default 30)
AUTH_RATE_LIMIT_MAX=30
